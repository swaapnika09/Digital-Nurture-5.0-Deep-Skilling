<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean id="sampleEmployee" class="com.cognizant.springlearn.model.Employee">
        <property name="id" value="1"/>
        <property name="name" value="Asha Rao"/>
        <property name="email" value="asha.rao@example.com"/>
        <property name="salary" value="65000"/>
        <property name="departmentId" value="1"/>
    </bean>

</beans>
